    description: "Exported function 'createUser' was removed"
    message: "Function 'createUser' was removed (function): Exported function 'createUser' was removed\n\nFile: src/api/users.d.ts"
    when:
      frontend.referenced:
        pattern: ^createUser$
        location: FUNCTION_CALL
  fix_strategy:
    strategy: Manual

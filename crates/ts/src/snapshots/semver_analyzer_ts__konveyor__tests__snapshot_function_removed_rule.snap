---
source: crates/ts/src/konveyor.rs
expression: snapshot_rules(rules)
---
- rule:
    ruleID: semver-src-api-users-d-ts-createuser-removed
    labels:
      - source=semver-analyzer
      - change-type=removed
      - kind=function
      - has-codemod=false
